@model TechMove.Controllers.ClientViewModel

@{
    ViewData["Title"] = "Create Client";
}

<div class="container mt-4 fade-in">
    <div class="mb-4">
        <h1>
            <i class="bi bi-person-plus"></i> Create New Client
        </h1>
        <p class="text-muted">Add a new client to the system with regional information</p>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="bi bi-info-circle"></i> Client Information
                    </h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        
                        <div class="mb-4">
                            <label asp-for="Name" class="form-label">
                                <i class="bi bi-person"></i> Client Name
                            </label>
                            <input asp-for="Name" class="form-control" placeholder="Enter client name" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-4">
                            <label asp-for="Region" class="form-label">
                                <i class="bi bi-globe"></i> Region
                            </label>
                            <select asp-for="Region" class="form-select">
                                <option value="">-- Select Region --</option>
                                <option value="Europe">🇪🇺 Europe (15% markup)</option>
                                <option value="North America">🌎 North America (10% markup)</option>
                                <option value="South Africa">🇿🇦 South Africa (5% markup)</option>
                                <option value="Other">🌍 Other (No markup)</option>
                            </select>
                            <span asp-validation-for="Region" class="text-danger"></span>
                            <small class="form-text text-muted">
                                <i class="bi bi-info-circle"></i> Region determines automatic pricing strategy adjustments
                            </small>
                        </div>
                        
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Create Client
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-x-circle"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="alert alert-info">
                <h6 class="alert-heading">
                    <i class="bi bi-lightbulb"></i> Regional Pricing Info
                </h6>
                <hr>
                <ul class="mb-0 small">
                    <li><strong>Europe:</strong> 15% markup</li>
                    <li><strong>North America:</strong> 10% markup</li>
                    <li><strong>South Africa:</strong> 5% markup</li>
                    <li><strong>Other:</strong> No markup</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}   