@model TechMove.Models.Client

@{
    ViewData["Title"] = "Delete Client";
}

<div class="container mt-4 fade-in">
    <div class="mb-4">
        <h1 class="text-danger">
            <i class="bi bi-exclamation-triangle"></i> Delete Client
        </h1>
        <p class="text-muted">Are you sure you want to delete this client?</p>
    </div>

    <div class="alert alert-danger">
        <h5 class="alert-heading">
            <i class="bi bi-exclamation-circle"></i> Warning: This action cannot be undone!
        </h5>
        <p class="mb-0">Deleting this client will permanently remove it from the system.</p>
    </div>

    <div class="card">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0">Client Details</h5>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">ID</dt>
                <dd class="col-sm-9">@Model.Id</dd>

                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@Model.Name</dd>

                <dt class="col-sm-3">Region</dt>
                <dd class="col-sm-9">
                    <span class="badge 
                        @(Model.Region switch {
                            "Europe" => "bg-primary",
                            "North America" => "bg-success",
                            "South Africa" => "bg-warning text-dark",
                            _ => "bg-secondary"
                        })">
                        @Model.Region
                    </span>
                </dd>

                <dt class="col-sm-3">Contracts</dt>
                <dd class="col-sm-9">
                    @if (Model.Contracts.Any())
                    {
                        <span class="badge bg-danger">@Model.Contracts.Count contract(s)</span>
                        <div class="alert alert-danger mt-2">
                            <i class="bi bi-x-circle"></i> This client has existing contracts and cannot be deleted.
                        </div>
                    }
                    else
                    {
                        <span class="badge bg-success">No contracts</span>
                    }
                </dd>
            </dl>
        </div>
    </div>

    <div class="mt-4">
        @if (!Model.Contracts.Any())
        {
            <form asp-action="Delete" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger" onclick="return confirm('Are you absolutely sure you want to delete this client?');">
                    <i class="bi bi-trash"></i> Confirm Delete
                </button>
            </form>
        }
        else
        {
            <button type="button" class="btn btn-danger" disabled>
                <i class="bi bi-trash"></i> Cannot Delete (Has Contracts)
            </button>
        }
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-x-circle"></i> Cancel
        </a>
    </div>
</div>
