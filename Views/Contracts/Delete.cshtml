@model TechMove.Models.Contract
@using TechMove.Models

@{
    ViewData["Title"] = "Delete Contract";
}

<div class="container mt-4 fade-in">
    <div class="mb-4">
        <h1 class="text-danger">
            <i class="bi bi-exclamation-triangle"></i> Delete Contract
        </h1>
        <p class="text-muted">Are you sure you want to delete this contract?</p>
    </div>

    <div class="alert alert-danger">
        <h5 class="alert-heading">
            <i class="bi bi-exclamation-circle"></i> Warning: This action cannot be undone!
        </h5>
        <p class="mb-0">Deleting this contract will permanently remove it and any associated files from the system.</p>
    </div>

    <div class="card">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0">Contract #@Model.Id Details</h5>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">ID</dt>
                <dd class="col-sm-9">@Model.Id</dd>

                <dt class="col-sm-3">Client</dt>
                <dd class="col-sm-9">@Model.Client.Name</dd>

                <dt class="col-sm-3">Region</dt>
                <dd class="col-sm-9">@Model.Client.Region</dd>

                <dt class="col-sm-3">Start Date</dt>
                <dd class="col-sm-9">@Model.StartDate.ToString("yyyy-MM-dd")</dd>

                <dt class="col-sm-3">End Date</dt>
                <dd class="col-sm-9">@Model.EndDate.ToString("yyyy-MM-dd")</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">
                    <span class="badge 
                        @(Model.Status switch
                        {
                            ContractStatus.Draft => "bg-secondary",
                            ContractStatus.Active => "bg-success",
                            ContractStatus.Expired => "bg-danger",
                            ContractStatus.OnHold => "bg-warning text-dark",
                            _ => "bg-secondary"
                        })">
                        @Model.Status
                    </span>
                </dd>

                <dt class="col-sm-3">Signed Agreement</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
                    {
                        <text><i class="bi bi-file-pdf text-danger"></i> PDF file will be deleted</text>
                    }
                    else
                    {
                        <span class="text-muted">No file</span>
                    }
                </dd>

                <dt class="col-sm-3">Service Requests</dt>
                <dd class="col-sm-9">
                    @if (Model.ServiceRequests.Any())
                    {
                        <span class="badge bg-danger">@Model.ServiceRequests.Count service request(s)</span>
                        <div class="alert alert-danger mt-2">
                            <i class="bi bi-x-circle"></i> This contract has existing service requests and cannot be deleted.
                        </div>
                    }
                    else
                    {
                        <span class="badge bg-success">No service requests</span>
                    }
                </dd>
            </dl>
        </div>
    </div>

    <div class="mt-4">
        @if (!Model.ServiceRequests.Any())
        {
            <form asp-action="Delete" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger" onclick="return confirm('Are you absolutely sure you want to delete this contract? This will also delete any uploaded files.');">
                    <i class="bi bi-trash"></i> Confirm Delete
                </button>
            </form>
        }
        else
        {
            <button type="button" class="btn btn-danger" disabled>
                <i class="bi bi-trash"></i> Cannot Delete (Has Service Requests)
            </button>
        }
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-x-circle"></i> Cancel
        </a>
    </div>
</div>
