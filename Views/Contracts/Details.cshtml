@model TechMove.Models.Contract
@using TechMove.Models

@{
    ViewData["Title"] = "Contract Details";
}

<div class="container mt-4">
    <h1>Contract Details</h1>
    <hr />

    <div class="card">
        <div class="card-header" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
            <h4><i class="bi bi-file-earmark-text"></i> Contract #@Model.Id</h4>
        </div>
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3"><i class="bi bi-person-circle"></i> Client</dt>
                <dd class="col-sm-9">@Model.Client.Name</dd>

                <dt class="col-sm-3"><i class="bi bi-globe"></i> Region</dt>
                <dd class="col-sm-9">
                    <span class="badge 
                        @(Model.Client.Region switch {
                            "Europe" => "bg-primary",
                            "North America" => "bg-success",
                            "South Africa" => "bg-warning text-dark",
                            _ => "bg-secondary"
                        })">
                        @Model.Client.Region
                    </span>
                </dd>

                <dt class="col-sm-3"><i class="bi bi-calendar-event"></i> Start Date</dt>
                <dd class="col-sm-9">@Model.StartDate.ToString("yyyy-MM-dd")</dd>

                <dt class="col-sm-3"><i class="bi bi-calendar-check"></i> End Date</dt>
                <dd class="col-sm-9">@Model.EndDate.ToString("yyyy-MM-dd")</dd>

                <dt class="col-sm-3"><i class="bi bi-diagram-3"></i> Status</dt>
                <dd class="col-sm-9">
                    <span class="badge 
                        @(Model.Status switch
                        {
                            ContractStatus.Draft => "bg-secondary",
                            ContractStatus.Active => "bg-success",
                            ContractStatus.Expired => "bg-danger",
                            ContractStatus.OnHold => "bg-warning text-dark",
                            _ => "bg-secondary"
                        })">
                        @Model.Status
                    </span>
                </dd>

                <dt class="col-sm-3"><i class="bi bi-file-earmark-pdf"></i> Signed Agreement</dt>
                <dd class="col-sm-9">
                    @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
                    {
                        <a asp-action="Download" asp-route-id="@Model.Id" class="btn btn-primary" style="padding: 0.5rem 1.25rem; font-size: 1rem;">
                            <i class="bi bi-download" style="font-size: 1.2rem;"></i> Download PDF
                        </a>
                    }
                    else
                    {
                        <span class="text-muted"><i class="bi bi-x-circle"></i> No file uploaded</span>
                    }
                </dd>

                <dt class="col-sm-3"><i class="bi bi-list-check"></i> Service Requests</dt>
                <dd class="col-sm-9">
                    <span class="badge bg-info" style="font-size: 1rem; padding: 0.5rem 0.75rem;">@Model.ServiceRequests.Count</span>
                </dd>
            </dl>
        </div>
    </div>

    <div class="mt-3 d-flex gap-2 flex-wrap">
        @if (Model.Status == ContractStatus.Active || Model.Status == ContractStatus.Draft)
        {
            <a asp-controller="ServiceRequests" asp-action="Create" asp-route-contractId="@Model.Id" class="btn btn-success" style="padding: 0.5rem 1.25rem;">
                <i class="bi bi-plus-circle-fill"></i> Create Service Request
            </a>
        }
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning" style="padding: 0.5rem 1.25rem;">
            <i class="bi bi-pencil-fill"></i> Edit
        </a>
        <a asp-action="Index" class="btn btn-secondary" style="padding: 0.5rem 1.25rem;">
            <i class="bi bi-arrow-left-circle"></i> Back to List
        </a>
    </div>

    @if (Model.ServiceRequests.Any())
    {
        <div class="mt-4">
            <h3><i class="bi bi-tools"></i> Service Requests</h3>
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th><i class="bi bi-hash"></i> ID</th>
                            <th><i class="bi bi-card-text"></i> Description</th>
                            <th><i class="bi bi-currency-dollar"></i> Cost (USD)</th>
                            <th><i class="bi bi-cash"></i> Cost (ZAR)</th>
                            <th><i class="bi bi-info-circle"></i> Status</th>
                            <th><i class="bi bi-calendar"></i> Created</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sr in Model.ServiceRequests)
                        {
                            <tr>
                                <td><strong>#@sr.Id</strong></td>
                                <td>@sr.Description</td>
                                <td>$@sr.CostUsd.ToString("N2")</td>
                                <td>R@sr.CostZar.ToString("N2")</td>
                                <td>
                                    <span class="badge 
                                        @(sr.Status switch
                                        {
                                            ServiceRequestStatus.Pending => "bg-warning text-dark",
                                            ServiceRequestStatus.InProgress => "bg-info",
                                            ServiceRequestStatus.Completed => "bg-success",
                                            ServiceRequestStatus.Cancelled => "bg-danger",
                                            _ => "bg-secondary"
                                        })">
                                        @sr.Status
                                    </span>
                                </td>
                                <td>@sr.CreatedDate.ToString("yyyy-MM-dd")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
