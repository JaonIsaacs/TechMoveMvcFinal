@{
    ViewData["Title"] = "Access Denied";
}

<div class="container text-center" style="margin-top: 100px;">
    <div class="mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" fill="currentColor" class="text-danger" viewBox="0 0 16 16">
            <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
            <path d="M11.354 4.646a.5.5 0 0 0-.708 0L8 7.293 5.354 4.646a.5.5 0 1 0-.708.708L7.293 8l-2.647 2.646a.5.5 0 0 0 .708.708L8 8.707l2.646 2.647a.5.5 0 0 0 .708-.708L8.707 8l2.647-2.646a.5.5 0 0 0 0-.708z"/>
        </svg>
    </div>
    
    <h1 class="display-4 fw-bold mb-3">Access Denied</h1>
    <p class="lead text-muted mb-4">You don't have permission to access this resource.</p>
    
    <div class="mt-4">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg me-2">Go Home</a>
        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary btn-lg">Sign In</a>
    </div>
</div>
