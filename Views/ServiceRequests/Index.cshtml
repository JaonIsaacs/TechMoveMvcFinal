@model IEnumerable<TechMove.Models.ServiceRequest>
@using TechMove.Models

@{
    ViewData["Title"] = "Service Requests";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Service Requests</h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Create New Service Request
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No service requests found. 
            <a asp-action="Create" class="alert-link">Create your first service request</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Contract</th>
                        <th>Client</th>
                        <th>Description</th>
                        <th>Cost (USD)</th>
                        <th>Cost (ZAR)</th>
                        <th>Exchange Rate</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var sr in Model)
                    {
                        <tr>
                            <td><strong>#@sr.Id</strong></td>
                            <td>
                                <a asp-controller="Contracts" asp-action="Details" asp-route-id="@sr.ContractId" class="text-decoration-none">
                                    Contract #@sr.ContractId
                                </a>
                            </td>
                            <td>@sr.Contract.Client.Name</td>
                            <td>
                                <span class="text-truncate d-inline-block" style="max-width: 200px;" title="@sr.Description">
                                    @sr.Description
                                </span>
                            </td>
                            <td class="text-end">
                                <strong>$@sr.CostUsd.ToString("N2")</strong>
                            </td>
                            <td class="text-end">
                                <strong>R @sr.CostZar.ToString("N2")</strong>
                            </td>
                            <td class="text-center">
                                <span class="badge bg-secondary">@sr.ExchangeRate.ToString("N2")</span>
                            </td>
                            <td>
                                <span class="badge 
                                    @(sr.Status switch
                                    {
                                        ServiceRequestStatus.Pending => "bg-warning text-dark",
                                        ServiceRequestStatus.InProgress => "bg-info",
                                        ServiceRequestStatus.Completed => "bg-success",
                                        ServiceRequestStatus.Cancelled => "bg-danger",
                                        _ => "bg-secondary"
                                    })">
                                    @sr.Status
                                </span>
                            </td>
                            <td class="text-nowrap">@sr.CreatedDate.ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="text-nowrap">
                                <form asp-action="Delete" asp-route-id="@sr.Id" method="post" style="display:inline;" 
                                      onsubmit="return confirm('Are you sure you want to delete Service Request #@sr.Id?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-3">
            <p class="text-muted">
                <i class="bi bi-info-circle"></i> 
                Showing <strong>@Model.Count()</strong> service request(s)
            </p>
        </div>
    }
</div>